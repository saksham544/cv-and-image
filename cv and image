<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title> ID Card</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial,sans-serif;
}

body{
    min-height:100vh;
    display:flex;
    justify-content:center;
    align-items:center;
    padding:20px;
    background:#111;
}



.id-card{
    width:100%;
    max-width:1100px;
    position:relative;
    overflow:hidden;
    border-radius:30px;
    padding:35px;

    background:url("background.jpg") center/cover no-repeat;

    border:1px solid rgba(255,255,255,.15);
    box-shadow:0 20px 40px rgba(0,0,0,.35);
}



.id-card::before{
    content:"";
    position:absolute;
    inset:0;
    background-image:url("o.jpg");
    background-size:cover   ;
    background-position:center;
    z-index:0;
}

.id-card > *{
    position:relative;
    z-index:1;
}



.glass{
    background:rgba(255,255,255,.06);
    backdrop-filter:blur(10px);
    -webkit-backdrop-filter:blur(10px);
    border:1px solid rgba(255,255,255,.15);
}


.title{
    text-align:center;
    color:rgba(255,255,255,.85);
    font-size:38px;
    margin-bottom:30px;
    letter-spacing:2px;
    text-shadow:0 2px 10px rgba(0,0,0,.6);
}



.profile-area{
    position:relative;
    height:300px;
    display:flex;
    justify-content:center;
    align-items:center;
}

.profile-photo{
    width:220px;
    height:220px;
    border-radius:50%;
    overflow:hidden;

    background:rgba(255,255,255,.05);
    backdrop-filter:blur(12px);

    border:4px solid rgba(255,255,255,.35);
}

.profile-photo img{
    width:100%;
    height:100%;
    object-fit:cover;
    opacity:.75;
    mix-blend-mode:screen;
}

.first-name,
.last-name{
    position:absolute;
    bottom:20px;
    font-size:32px;
    font-weight:bold;
    color:rgba(12, 169, 232, 0.7);
    text-shadow:0 2px 8px rgba(0,0,0,.7);
    line-height: normal;
    letter-spacing:auto;
    text-decoration: underline;
    
    
}

.first-name{
    right:20px;
    text-underline-position: under;
    text-decoration: underline;

}

.last-name{
    left:20px;
}



.preview-box{
    height:350px;
    margin-top:20px;
    margin-bottom:30px;
    overflow:hidden;
    border-radius:25px;
}

.preview-box img{
    width:100%;
    height:100%;
    object-fit:cover;
    opacity:.6;
    mix-blend-mode:screen;
}



.thumbnail-row{
    display:flex;
    justify-content:center;
    align-items:center;
    overflow-x:auto;
    padding:10px 0 30px;
    scrollbar-width:none;
}

.thumbnail-row::-webkit-scrollbar{
    display:none;
}

.thumb{
    width:90px;
    height:90px;
    flex-shrink:0;
    overflow:hidden;
    border-radius:14px;
    cursor:pointer;

    margin-left:-40px;

    background:rgba(255,255,255,.05);
    backdrop-filter:blur(10px);

    border:2px solid rgba(255,255,255,.25);

    transition:.3s;
}

.thumb:first-child{
    margin-left:0;
}

.thumb img{
    width:100%;
    height:100%;
    object-fit:cover;
    opacity:.6;
    mix-blend-mode:screen;
}

.thumb:hover,
.thumb.active{
    transform:translateY(-10px) scale(1.08);
    z-index:10;
}


.gallery{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(180px,1fr));
    gap:20px;
}

.card{
    height:180px;
    overflow:hidden;
    border-radius:20px;
}

.card img{
    width:100%;
    height:100%;
    object-fit:cover;
    opacity:.55;
    mix-blend-mode:screen;
    transition:.3s;
}

.card:hover img{
    opacity:.85;
    transform:scale(1.1);
}


.about-me{
    margin-top:40px;
    padding:30px;
    border-radius:25px;
}

.about-me h2{
    color:rgba(255,255,255,.85);
    margin-bottom:20px;
    text-align:center;
    font-size:30px;
}

.about-me p{
    color:rgba(255,255,255,.7);
    line-height:1.9;
    font-size:18px;
    text-align:justify;
}



.footer{
    margin-top:30px;
    padding:25px;
    border-radius:25px;
    text-align:center;
}

.footer p{
    color:rgba(255,255,255,.65);
    margin:8px 0;
}
.footer contact-info{
    color:rgba(255,255,255,.65);
    margin:8px 0;
    display:block;
}



.preview-box,
.card,
.about-me,
.footer{
    background:rgba(255,255,255,.05);
    backdrop-filter:blur(10px);
    -webkit-backdrop-filter:blur(10px);
    border:1px solid rgba(255,255,255,.12);
}



@media(max-width:768px){

    .id-card{
        padding:20px;
    }

    .title{
        font-size:28px;
    }

    .profile-area{
        height:240px;
    }

    .profile-photo{
        width:160px;
        height:160px;
    }

    .first-name,
    .last-name{
        font-size:20px;
        bottom:10px;
    }

    .preview-box{
        height:220px;
    }

    .thumb{
        width:65px;
        height:65px;
        margin-left:-25px;
    }

    .about-me p{
        font-size:16px;
    }
}
</style>
</head>

